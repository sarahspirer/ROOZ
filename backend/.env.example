NODE_ENV=development
PORT=3001

# PostgreSQL — run: docker compose up postgres -d
DATABASE_URL=postgresql://phocus:phocus_dev_password@localhost:5432/phocus

# Redis — run: docker compose up redis -d
REDIS_URL=redis://localhost:6379

# JWT — must be at least 32 characters
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# Dashboard origin for CORS
CORS_ORIGIN=http://localhost:5173

# Heartbeat timeout (ms) — students marked offline after this
HEARTBEAT_TIMEOUT_MS=120000
