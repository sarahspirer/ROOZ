{
  "expo": {
    "name": "ROOZ",
    "slug": "rooz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rooz.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "ROOZ checks that you're on school grounds during class to track focus compliance."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080808"
      },
      "package": "com.rooz.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-location",
      [
        "expo-background-fetch",
        {
          "minimumInterval": 60
        }
      ]
    ],
    "scheme": "rooz",
    "extra": {
      "apiUrl": "https://sweet-unity-production-8389.up.railway.app",
      "socketUrl": "https://sweet-unity-production-8389.up.railway.app",
      "eas": {
        "projectId": "f656aa76-cf86-41da-8dfa-c14190da9fd1"
      }
    }
  }
}
